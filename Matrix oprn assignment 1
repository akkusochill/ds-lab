#include <stdio.h>
#include <stdlib.h>
void accept(int mat[10][10], int rows, int cols){
    printf("Enter the values of matrix");
    for (int i=0;i<rows;i++){
        for (int j=0;j<cols;j++){
            scanf("%d", &mat[i][j]);
        }
    }
}

void display(int mat[10][10], int rows, int cols){
    printf("Matrix is:\n");
    for (int i=0;i<rows;i++){
        for(int j=0;j<cols; j++){
            printf("\t %d", mat[i][j]);
        }
        printf("\n");
    }
}


void addition(int mat1[10][10], int mat2[10][10], int row, int cols){
    int mat3[10][10];
   
    for (int i=0; i<row; i++){
        for (int j=0;i<cols;j++){
            mat3[i][j]= mat1[i][j]+ mat2[i][j];
        }
    }
    printf("Resultant matrix:\n");
    display(mat3, row, cols);
}

void subtraction(int mat1[10][10], int mat2[10][10], int row, int cols){
    int mat3[10][10];
   
    for (int i=0; i<row; i++){
        for (int j=0;j<cols;j++){
            mat3[i][j]= mat1[i][j]- mat2[i][j];
        }
    }
    printf("Resultant matrix:\n");
    display(mat3, row, cols);
}

void transpose(int mat[10][10], int rows, int cols){
    int trans[10][10];
    for (int i=0; i<rows;i++){
        for (int j=0; j<cols; j++){
            trans[i][j]= mat[j][i];
       
        }
    }
    printf("Transpose mat is: \n");
    display(trans, cols, rows);
}

void multiplication(int mat1[10][10], int mat2[10][10],
                    int r1, int c1, int r2, int c2) {
    int result[10][10] = {0};
    if (c1 != r2) {
        printf("Matrix multiplication is not possible.\n");
        return;
    }
    for (int i = 0; i < r1; i++) {
        for (int j = 0; j < c2; j++) {
            for (int k = 0; k < c1; k++) {
                result[i][j] += mat1[i][k] * mat2[k][j];
            }
        }
    }
    printf("Resultant matrix is:\n");
    display(result, r1, c2);
}


int main() {
    // Write C code here
    int m, n, ch;
    int array1[10][10], array2[10][10];
   
    printf("Enter rows and columns for matrices: ");
    scanf("%d%d", &m, &n);
   
    printf("Enter Matrix 1: \n");
    accept(array1, m , n);
    display(array1, m ,n);
    printf("Enter matrix 2: \n");
    accept(array2, m , n);
    display(array2, m , n);
   
   
    while(1){
        printf("====MENU====");
        printf("\n1. addition");
        printf("\n2. subtraction");
        printf("\n3. transpose");
        printf("\n4. multiplication");
        printf("\n5. exit");
        printf("\nSelect the operation:");
        scanf("%d", &ch);
       
       
        switch(ch){
            case 1:
                addition(array1, array2, m, n);
                break;
            case 2:
                subtraction(array1, array2, m, n);
                break;
            case 3:
                printf("Transpose of mat 1:");
                transpose(array1, m, n);
               
                printf("Transpose of mat 2:");
                transpose(array2, m, n);
                break;
               
            case 4:
                multiplication(array1, array2, m, n, m, n);
                break;
            case 5:
                exit(0);
               
            default:
                printf("\n Invalid Choice!");
       
           
        }
       
    }

    return 0;
}
